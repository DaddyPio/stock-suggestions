# ---- LLM（摘要與情緒判斷）----
# 與 Claude Pro 獨立計費，啟用前確認費用
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# 情緒判斷用便宜模型，摘要用較強模型（可調）
SENTIMENT_MODEL=claude-haiku-4-5-20251001
SUMMARY_MODEL=claude-sonnet-4-6

# ---- 寄信（Gmail SMTP）----
# 在 Google 帳號開啟兩步驟驗證後，產生「應用程式密碼」貼在這裡（16 碼，無空格）
GMAIL_ADDRESS=youraddress@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# 收件者（預設寄給自己；多人用逗號分隔）
EMAIL_TO=youraddress@gmail.com

# ---- 其他（選用）----
# 每日取前幾名
TOP_N=10
# 綜合分權重：討論度 / 推薦度
WEIGHT_DISCUSSION=0.6
WEIGHT_RECOMMENDATION=0.4
